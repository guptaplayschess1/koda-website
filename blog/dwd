  .btn-primary {
    display: inline-block;
    background: var(--red);
    color: var(--white);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 18px 40px;
