    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .hero-left::before {
    content: 'KODA';
    position: absolute;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 280px;
    color: rgba(255,255,255,0.03);
    bottom: -40px;
    left: -20px;
    pointer-events: none;
    letter-spacing: -0.02em;
  }

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 24px;
  }

  .hero-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(56px, 6vw, 84px);
    line-height: 0.95;
    color: var(--white);
    letter-spacing: 0.02em;
    margin-bottom: 32px;
  }

  .hero-headline em {
    color: var(--red);
    font-style: normal;
  }

  .hero-body {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(245,242,236,0.6);
